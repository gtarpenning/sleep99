default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:               ENV["ASC_KEY_ID"],
      issuer_id:            ENV["ASC_ISSUER_ID"],
      key_content:          ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house:             false
    )

    match(
      type:              "appstore",
      readonly:          true,
      api_key:           api_key,
      keychain_name:     "build.keychain",
      keychain_password: ""
    )

    current_build = latest_testflight_build_number(
      api_key:        api_key,
      app_identifier: "com.sleep-tune.app"
    ) rescue 0
    increment_build_number(
      build_number: (current_build.to_i + 1).to_s,
      xcodeproj:    "SleepTune.xcodeproj"
    )

    gym(
      scheme:           "SleepTune",
      project:          "SleepTune.xcodeproj",
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "./build_output",
      output_name:      "SleepTune.ipa",
      clean:            true,
      xcargs:           "CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=JL39GTJ62X " \
                        "PROVISIONING_PROFILE_SPECIFIER='match AppStore com.sleep-tune.app' " \
                        "OTHER_CODE_SIGN_FLAGS='--keychain build.keychain'",
      export_options: {
        method:               "app-store",
        teamID:               "JL39GTJ62X",
        provisioningProfiles: { "com.sleep-tune.app" => "match AppStore com.sleep-tune.app" },
        signingStyle:         "manual"
      }
    )

    pilot(
      api_key:                           api_key,
      app_identifier:                    "com.sleep-tune.app",
      ipa:                               "./build_output/SleepTune.ipa",
      skip_waiting_for_build_processing: true,
      changelog: ENV.fetch("RELEASE_NOTES", "Automated build")
    )

    commit_version_bump(
      message:   "chore: bump build number [skip ci]",
      xcodeproj: "SleepTune.xcodeproj",
      force:     true
    )
    push_to_git_remote
  end

  desc "Bootstrap certs (run once — creates dist cert + provisioning profile)"
  lane :bootstrap_certs do
    api_key = app_store_connect_api_key(
      key_id:               ENV["ASC_KEY_ID"],
      issuer_id:            ENV["ASC_ISSUER_ID"],
      key_content:          ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house:             false
    )

    match(
      type:     "appstore",
      readonly: false,
      api_key:  api_key
    )
  end

end
